{
  "name": "specferret-workspace",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "tree-sitter": "^0.22.4",
    "tree-sitter-typescript": "^0.23.2"
  },
  "workspaces": [
    "packages/core",
    "packages/cli",
    "apps/site"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "site:dev": "bun run --filter @specferret/site dev",
    "site:build": "bun run --filter @specferret/site build",
    "site:preview": "bun run --filter @specferret/site preview",
    "bootstrap:validation": "bun scripts/bootstrap-validation-repo.ts",
    "smoke:s34": "bun scripts/smoke-s34.ts --mode clean --ferret-entry packages/cli/dist/bin/ferret.js",
    "smoke:s34:drift": "bun scripts/smoke-s34.ts --mode drift --ferret-entry packages/cli/dist/bin/ferret.js"
  }
}
